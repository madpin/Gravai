{
  "productName": "Gravai Dev",
  "identifier": "com.gravai.app.dev",
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/.gravai-dev/sessions/**/*",
            "$HOME/.gravai/sessions/**/*"
          ]
        }
      }
    },
    "windows": [
      {
        "title": "Gravai Dev",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
