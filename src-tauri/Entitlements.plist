<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox disabled: enabling this breaks the Tauri in-app updater on macOS —
         the sandbox prevents the updater from moving the new .app bundle into place,
         causing an immediate "Failed to move the new app into place" error. Since this
         app is distributed via GitHub releases (not the App Store) and is unsigned,
         sandboxing provides no benefit and actively breaks self-update.
         Re-enable only if targeting the Mac App Store, and switch to a privileged
         helper or external update mechanism instead.
    <key>com.apple.security.app-sandbox</key>
    <true/> -->

    <!-- Microphone access for audio recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Screen Recording for ScreenCaptureKit system audio -->
    <key>com.apple.security.device.screen-capture</key>
    <true/>

    <!-- Network access for BYOK LLM APIs, Notion, model downloads -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Read/write user-selected files (export to custom folders) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Calendar access for meeting detection -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
</dict>
</plist>
