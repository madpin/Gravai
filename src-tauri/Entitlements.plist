<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox (required for App Store) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Microphone access for audio recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Screen Recording for ScreenCaptureKit system audio -->
    <key>com.apple.security.device.screen-capture</key>
    <true/>

    <!-- Network access for BYOK LLM APIs, Notion, model downloads -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Read/write user-selected files (export to custom folders) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Calendar access for meeting detection -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
</dict>
</plist>
